PUBLIC_PB_URL=http://127.0.0.1:8090
GOOGLE_MAPS_API_KEY=
AERODATABOX_API_KEY=
RESEND_API_KEY=
# FROM address for outbound Waypoint email. Domain (vandenwarsen.com) must be
# verified in Resend. PB reads this at startup; the SvelteKit side does not
# need it. Used by /api/dev/resend-smoke today; M2b will use it for invites.
RESEND_FROM=hello@vandenwarsen.com

# Dev-only: enables /api/dev/login + PB /api/dev/auth-bypass for E2E tests.
# Leave blank / unset in production. Must be set in BOTH the SvelteKit env and
# the environment PocketBase is launched with.
WAYPOINT_DEV_MODE=
E2E_TEST_EMAIL=e2e@waypoint.local
# Comma-separated whitelist for the M2a rules harness (test-rules.mjs).
# PB-side only. Leave blank / unset in production.
E2E_TEST_EMAILS=

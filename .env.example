PUBLIC_PB_URL=http://127.0.0.1:8090
# Optional: server-side (SSR) PB base URL. In prod set this to an on-box URL
# (e.g. http://localhost:8090) so SSR calls skip the public Cloudflare Tunnel.
# Unset falls back to PUBLIC_PB_URL. Browser always uses PUBLIC_PB_URL.
PB_INTERNAL_URL=
PUBLIC_APP_URL=http://localhost:5173
GOOGLE_MAPS_API_KEY=
AERODATABOX_API_KEY=
RESEND_API_KEY=
RESEND_FROM=hello@vandenwarsen.com

# SMTP settings for PocketBase OTP emails. In production, use Resend's SMTP
# relay (smtp.resend.com:465, API key as password). The smtp.pb.js boot hook
# reads these and configures PB automatically.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=

# PocketBase superuser credentials. Used by the public archive route (bypasses
# collection rules) and by `pnpm clean:dev-trips` (scripts/clean-dev-trips.mjs,
# which deletes throwaway E2E trips and so needs superuser auth).
# backend/start.sh upserts this superuser on every dev boot (headless), so the
# dashboard never shows its first-run install/login screen (#102). Leave unset to
# get the localhost default admin@waypoint.dev; set both to pin your own creds.
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=

# Dev-only: enables /api/dev/login + PB /api/dev/auth-bypass for E2E tests.
# Leave blank / unset in production. Must be set in BOTH the SvelteKit env and
# the environment PocketBase is launched with.
WAYPOINT_DEV_MODE=
E2E_TEST_EMAIL=e2e@waypoint.local
# Comma-separated whitelist for the M2a rules harness (test-rules.mjs).
# PB-side only. Leave blank / unset in production.
E2E_TEST_EMAILS=

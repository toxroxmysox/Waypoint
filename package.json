{
	"name": "waypoint",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "playwright install && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:clean": "bash scripts/e2e-isolated.sh",
		"clean:dev-trips": "node scripts/clean-dev-trips.mjs",
		"test:rules": "node backend/test-rules.mjs",
		"test:invites": "node backend/test-invites.mjs",
		"test:members": "node backend/test-members.mjs",
		"test:suggestions": "node backend/test-suggestions.mjs",
		"test:money": "node backend/test-money.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"dotenv": "^17.4.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.1.0",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"bits-ui": "^2.17.3",
		"formsnap": "^2.0.1",
		"pocketbase": "^0.26.8",
		"svelte-dnd-action": "^0.9.69",
		"sveltekit-superforms": "^2.30.1",
		"zod": "^4.3.6"
	}
}
